PORT=3000
GIGACALLER_GATEWAY_WS_URL=ws://localhost:8080
GIGACALLER_GATEWAY_USERNAME=
GIGACALLER_GATEWAY_PASSWORD=
# Set to false only for local stands with untrusted certificates.
GIGACALLER_GATEWAY_TLS_REJECT_UNAUTHORIZED=true
DEFAULT_RETRY=0
DEFAULT_VOICE=Bik-Freespeech_8000

# Optional. Authorization Key from https://developers.sber.ru/studio.
GIGACHAT_API_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_TLS_REJECT_UNAUTHORIZED=true
GIGACHAT_AUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_MODEL=GigaChat
